<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="24dp">

    <TextView
        android:text="Women Safety Companion"
        android:textSize="20sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:text="Shake your phone or press SOS to alert contacts"
        android:textSize="13sp"
        android:textColor="#aaaaaa"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnSOS"
        android:text="SOS"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:backgroundTint="#e63946"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnContacts"
            android:text="Contacts"
            android:backgroundTint="#457b9d"
            android:textColor="#ffffff"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnMap"
            android:text="Live Map"
            android:backgroundTint="#457b9d"
            android:textColor="#ffffff"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnFakeCall"
        android:text="Fake Call"
        android:backgroundTint="#2d6a4f"
        android:textColor="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>